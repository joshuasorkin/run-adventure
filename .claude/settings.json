{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run test *)",
      "Bash(npm run lint)",
      "Bash(npm run typecheck)",
      "Bash(npx playwright test *)",
      "Read(./**)",
      "Edit(./**)",
      "Write(./**)",
      "Bash(npx prisma *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Bash(rm -rf *)",
      "Bash(rd /s *)",
      "Bash(del /f *)"
    ]
  }
}